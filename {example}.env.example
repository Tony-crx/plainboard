# CortisolBoard Environment Variables
# Copy this file to .env.local and fill in the required values

# ==================== AUTHENTICATION (REQUIRED) ====================
# Session secret - must be a secure random string (at least 32 characters)
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Login password - used for simple password-based authentication
LOGIN_PASSWORD=

# ==================== LLM PROVIDERS (REQUIRED) ====================
# OpenRouter API keys (comma-separated for key rotation)
# Get keys from: https://openrouter.ai/keys
OPENROUTER_KEYS=

# Groq API keys (comma-separated for key rotation)
# Get keys from: https://console.groq.com/keys
GROQ_KEYS=

# ==================== OPTIONAL CONFIGURATION ====================
# Enable coordinator mode for the swarm (true/false)
# COORDINATOR_MODE=false

# Public site URL (used for OpenRouter API referer header)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin password for API access (fallback to LOGIN_PASSWORD if not set)
# ADMIN_PASSWORD=

# Safe directory for file/terminal operations (defaults to project sandbox)
# SAFE_DIR=

# ==================== PRODUCTION NOTES ====================
# 1. NEVER commit .env.local to version control
# 2. Use different values for development, staging, and production
# 3. Rotate API keys regularly
# 4. SESSION_SECRET must be cryptographically secure random string
# 5. On Vercel, set these in Project Settings > Environment Variables
